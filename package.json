{
  "name": "@briang7/designkit",
  "version": "0.0.1",
  "description": "Framework-agnostic UI component library built with Lit Web Components",
  "type": "module",
  "main": "dist/designkit.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/designkit.umd.cjs"
    },
    "./themes/*": "./dist/themes/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "web-components",
    "lit",
    "ui-library",
    "design-system"
  ],
  "author": "Brian G",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/briang7/designkit.git"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/web-components": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "eslint": "^9.39.3",
    "lit-analyzer": "^2.0.3",
    "storybook": "^8.6.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
