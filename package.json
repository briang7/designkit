{
  "name": "@briang7/designkit",
  "version": "0.3.6",
  "description": "Framework-agnostic UI component library built with Lit Web Components",
  "type": "module",
  "main": "dist/designkit.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/designkit.umd.cjs"
    },
    "./themes/*": "./dist/themes/*",
    "./button": {
      "import": "./dist/components/button/index.js"
    },
    "./badge": {
      "import": "./dist/components/badge/index.js"
    },
    "./avatar": {
      "import": "./dist/components/avatar/index.js"
    },
    "./input": {
      "import": "./dist/components/input/index.js"
    },
    "./checkbox": {
      "import": "./dist/components/checkbox/index.js"
    },
    "./switch": {
      "import": "./dist/components/switch/index.js"
    },
    "./select": {
      "import": "./dist/components/select/index.js"
    },
    "./card": {
      "import": "./dist/components/card/index.js"
    },
    "./tooltip": {
      "import": "./dist/components/tooltip/index.js"
    },
    "./tabs": {
      "import": "./dist/components/tabs/index.js"
    },
    "./dialog": {
      "import": "./dist/components/dialog/index.js"
    },
    "./drawer": {
      "import": "./dist/components/drawer/index.js"
    },
    "./toast": {
      "import": "./dist/components/toast/index.js"
    },
    "./accordion": {
      "import": "./dist/components/accordion/index.js"
    },
    "./alert": {
      "import": "./dist/components/alert/index.js"
    },
    "./breadcrumbs": {
      "import": "./dist/components/breadcrumbs/index.js"
    },
    "./pagination": {
      "import": "./dist/components/pagination/index.js"
    },
    "./dropdown": {
      "import": "./dist/components/dropdown/index.js"
    },
    "./progress": {
      "import": "./dist/components/progress/index.js"
    },
    "./rating": {
      "import": "./dist/components/rating/index.js"
    },
    "./divider": {
      "import": "./dist/components/divider/index.js"
    },
    "./search-input": {
      "import": "./dist/components/search-input/index.js"
    },
    "./data-table": {
      "import": "./dist/components/data-table/index.js"
    },
    "./skeleton": {
      "import": "./dist/signature/skeleton/index.js"
    },
    "./command": {
      "import": "./dist/signature/command/index.js"
    },
    "./form": {
      "import": "./dist/signature/form/index.js"
    },
    "./sections": {
      "import": "./dist/sections.js"
    },
    "./sections/navbar": {
      "import": "./dist/sections/navbar/index.js"
    },
    "./sections/hero": {
      "import": "./dist/sections/hero/index.js"
    },
    "./sections/footer": {
      "import": "./dist/sections/footer/index.js"
    },
    "./sections/features": {
      "import": "./dist/sections/features/index.js"
    },
    "./sections/testimonials": {
      "import": "./dist/sections/testimonials/index.js"
    },
    "./sections/cta": {
      "import": "./dist/sections/cta/index.js"
    },
    "./sections/stats": {
      "import": "./dist/sections/stats/index.js"
    },
    "./sections/pricing": {
      "import": "./dist/sections/pricing/index.js"
    },
    "./sections/faq": {
      "import": "./dist/sections/faq/index.js"
    },
    "./sections/newsletter": {
      "import": "./dist/sections/newsletter/index.js"
    },
    "./sections/gallery": {
      "import": "./dist/sections/gallery/index.js"
    },
    "./sections/sidebar": {
      "import": "./dist/sections/sidebar/index.js"
    },
    "./sections/team": {
      "import": "./dist/sections/team/index.js"
    },
    "./sections/contact": {
      "import": "./dist/sections/contact/index.js"
    },
    "./sections/logo-cloud": {
      "import": "./dist/sections/logo-cloud/index.js"
    },
    "./sections/blog": {
      "import": "./dist/sections/blog/index.js"
    },
    "./sections/timeline": {
      "import": "./dist/sections/timeline/index.js"
    },
    "./sections/products": {
      "import": "./dist/sections/products/index.js"
    },
    "./sections/categories": {
      "import": "./dist/sections/categories/index.js"
    },
    "./sections/banner": {
      "import": "./dist/sections/banner/index.js"
    },
    "./sections/error": {
      "import": "./dist/sections/error/index.js"
    },
    "./react": {
      "types": "./src/react.d.ts"
    }
  },
  "files": [
    "dist",
    "src/react.d.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "keywords": [
    "web-components",
    "lit",
    "ui-library",
    "design-system"
  ],
  "author": "Brian G",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/briang7/designkit.git"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "motion": "^12.35.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-replace": "^6.0.3",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/web-components": "^8.6.18",
    "@storybook/web-components-vite": "^8.6.18",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "eslint": "^9.39.3",
    "lit-analyzer": "^2.0.3",
    "storybook": "^8.6.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
